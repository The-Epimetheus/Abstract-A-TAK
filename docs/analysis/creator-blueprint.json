  "banded": [
    {
      "creator": "RadioCreator",
      "feature": "radio",
      "bands": [
        {
          "versions": [
            "4.10",
            "5.0"
          ],
          "note": "RadioMapComponent.registerControl(View) / unregisterControl(View) \u2014 no String key parameter.",
          "impl": "src/atak410/RadioCreatorImpl",
          "impl_detail": "registerControl(View)/unregisterControl(View)"
        },
        {
          "versions": [
            "5.1",
            "5.2",
            "5.3",
            "5.4",
            "5.5",
            "5.6",
            "5.7",
            "5.8"
          ],
          "note": "RadioMapComponent gained a String key: registerControl(String,View) / unregisterControl(String). This member-signature change splits the band at the 5.0->5.1 boundary.",
          "impl": "src/atak510/RadioCreatorImpl",
          "impl_detail": "registerControl(String,View)/unregisterControl(String)"
        }
      ]
    },
    {
      "creator": "LayerDownloadCreator",
      "feature": "layers",
      "bands": [
        {
          "versions": [
            "4.10",
            "5.0"
          ],
          "note": "RasterUtils.getCurrentImagery(MapView,GeoBounds):List<ImageDatasetDescriptor> is the imagery-enumeration entry point.",
          "impl": "src/atak410/LayerDownloadCreatorImpl",
          "impl_detail": "RasterUtils.getCurrentImagery(MapView,GeoBounds)"
        },
        {
          "versions": [
            "5.1",
            "5.2",
            "5.3",
            "5.4",
            "5.5",
            "5.6",
            "5.7",
            "5.8"
          ],
          "note": "RasterUtils.getCurrentImagery was replaced by RasterUtils.queryDatasets(GeoBounds,boolean):List<DatasetDescriptor> (signature+return-type change). LayerDownloader/OSMUtils/DownloadJob themselves are unchanged, so only the RasterUtils call is banded.",
          "impl": "src/atak510/LayerDownloadCreatorImpl",
          "impl_detail": "RasterUtils.queryDatasets(GeoBounds,boolean)"
        }
      ]
    }
  ],
  "divergences": [
    {
      "versions": "4.10, 5.0  ->  5.1, 5.2, 5.3, 5.4, 5.5, 5.6, 5.7, 5.8",
      "atakType": "com.atakmap.android.radiolibrary.RadioMapComponent",
      "change": "registerControl(View) / unregisterControl(View)  ->  registerControl(String key, View) / unregisterControl(String key). A String control key parameter was added at 5.1; forces RadioCreator to split into [4.10,5.0] and [5.1+] bands."
    },
    {
      "versions": "4.10, 5.0  ->  5.1, 5.2, 5.3, 5.4, 5.5, 5.6, 5.7, 5.8",
      "atakType": "com.atakmap.android.layers.RasterUtils",
      "change": "static List<ImageDatasetDescriptor> getCurrentImagery(MapView, GeoBounds)  ->  static List<DatasetDescriptor> queryDatasets(GeoBounds, boolean). Method renamed and both parameter list and element/return type changed at 5.1; forces LayerDownloadCreator's imagery-enumeration call to split into [4.10,5.0] and [5.1+] bands."
    },
    {
      "versions": "5.0  ->  5.1, 5.2, 5.3, 5.4, 5.5, 5.6, 5.7, 5.8",
      "atakType": "com.atakmap.android.routes.Route",
      "change": "5.1 adds setLabels(...) and setMetaMap(...) to Route (5.0 route population used addMarkers/createWayPoint only). ADDITIVE / source-compatible \u2014 noted for completeness; does not force a band because the pre-existing members are unchanged."
    },
    {
      "versions": "4.10  ->  5.0 (transcription-level, UNCONFIRMED)",
      "atakType": "com.atakmap.android.maps.SensorFOV",
      "change": "setMetrics transcribed as (int,int,int) in 4.10 and 5.1 but (float,float,float) in 5.0. Almost certainly transcription noise (javap was unavailable in every inventory). If a real int->float overload swap is confirmed by javap, it band-splits ShapeCreator; otherwise treat ShapeCreator as stable-all."
    },
    {
      "versions": "4.10..5.8 (UNCONFIRMED, highest re-verify risk)",
      "atakType": "com.atakmap.map.opengl.GLMapView",
      "change": "GLSpecialMarker reads public/protected GLMapView fields directly (scratch.geo, scratch.pointD, idlHelper.wrapLongitude, currentPass.drawTilt, renderPass, context) plus GLPointMapItem2 fields (latitude/longitude/altHae). Public render-internal fields are the most likely surface to churn between minor versions; byte-confirm per version. Any confirmed field rename/removal band-splits MapEngineCreator/GLMapItemCreator at that boundary."
    },
    {
      "versions": "4.10..5.8 (class-level, CONFIRMED stable)",
      "atakType": "~230 distinct com.atakmap.*/gov.tak.*/com.atak.* types",
      "change": "The 4.10 inventory verified every imported ATAK type (incl. inner types: PlacePointTool$MarkerCreator, CotServiceRemote$ConnectionListener/$OutputsChangedListener, ContactConnectorManager$ContactConnectorHandler, CoordinateEntryCapability$ResultCallback, DangerCloseReceiver$ExternalMunitionQuery, etc.) resolves in 4.10 main.jar with 0 missing. No CLASS-level 4.10-vs-5.0 delta exists for this plugin's surface; all confirmed method-level divergences are the two above (RadioMapComponent, RasterUtils)."
    }
  ],

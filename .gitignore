.DS_Store
REPO_README.txt

# (From GitHub: https://raw.githubusercontent.com/github/gitignore/master/Android.gitignore)
# Built application files
*.apk
*.ap_

# swap files
*.swp

# add in profiler dumps
*.hprof
*.prof

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
/build
/.gradle
out/

# Gradle files
.gradle/
build/

# Local configuration file (sdk path, etc)
local.properties

# Proguard folder generated by Eclipse
proguard/

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# Intellij
*.iml
.idea
.idea/workspace.xml
.idea/tasks.xml
.idea/gradle.xml
.idea/dictionaries
.idea/libraries

# Keystore files
*.jks

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild

# Google Services (e.g. APIs or Firebase)
google-services.json

# Freeline
freeline.py
freeline/
freeline_project_description.json


# sdk stuff
sdk/main.jar
sdk/android_keystore
# per-version ATAK SDK jars (large, licensed — keep local). README stays tracked.
sdk/main-*.jar
!sdk/README.md

#espresso
espresso

# Local development-time mirrors — NOT part of the reference repo. See README for
# where to obtain the ATAK SDK; `just sync-sdk` stages jars from this mirror when
# present, but the repo must remain understandable without it.
HelloWorld_Collection/
atak-docs/

# takdev devkit cache
.takdev/

# TAK's well-known dev keystore (staged from the SDK bundle by `just sync-sdk`;
# takdev generates one automatically when the devkit is configured)
keystore/

# Dev-bridge artifacts (scripts stay tracked; generated captures/dumps don't —
# *.log and *.apk are already ignored globally above)
build-tools/*.png
build-tools/ui.xml
build-tools/logcat-*.txt
# NOTE: build-tools/atak-gradle-takdev.jar IS committed — the ATAK-CIV gradle dev
# plugin (Apache-2.0), needed for the build to configure locally and in CI.
dist/
